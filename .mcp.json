{
  "version": "1.0",
  "metadata": {
    "project": "HR Microservices",
    "description": "ECC + CodeGraph Integration",
    "created": "2026-05-23"
  },
  "mcpServers": {
    "ecc": {
      "command": "node",
      "args": ["node_modules/.bin/ecc-mcp"],
      "env": {
        "ECC_PROJECT_ROOT": ".",
        "ECC_HOOK_PROFILE": "standard",
        "ECC_AGENTS_PATH": "agents/",
        "ECC_SKILLS_PATH": "skills/"
      },
      "enabled": true
    },
    "codegraph": {
      "command": "node",
      "args": ["node_modules/.bin/codegraph", "mcp"],
      "env": {
        "CODEGRAPH_DB": ".codegraph/index.db",
        "CODEGRAPH_AUTO_SYNC": "true",
        "CODEGRAPH_SYNC_DEBOUNCE_MS": "2000"
      },
      "enabled": true
    }
  },
  "tools": {
    "ecc": {
      "available": [
        "ecc-config",
        "ecc-agents",
        "ecc-skills",
        "ecc-hooks",
        "continuous-learning",
        "harness-audit",
        "security-scan"
      ]
    },
    "codegraph": {
      "available": [
        "codegraph_context",
        "codegraph_explore",
        "codegraph_impact",
        "codegraph_search",
        "codegraph_sync"
      ]
    }
  },
  "agents": {
    "enabled": [
      "hr-domain-expert",
      "spring-reviewer",
      "database-expert"
    ],
    "paths": {
      "configs": "agents/",
      "examples": "agents/"
    }
  },
  "skills": {
    "enabled": [
      "payroll-patterns",
      "employee-lifecycle",
      "compliance-audit",
      "springboot-patterns"
    ],
    "paths": {
      "definitions": "skills/"
    }
  },
  "permissions": {
    "ecc": {
      "workspace": "read",
      "filesystem": "read",
      "config": "read-write"
    },
    "codegraph": {
      "workspace": "read",
      "filesystem": ["read", "watch"],
      "database": "read-write"
    }
  },
  "hooks": {
    "continuous-learning": {
      "enabled": true,
      "trigger": "session-end",
      "path": "hooks/continuous-learning.js"
    }
  },
  "performance": {
    "codegraph": {
      "cache_ttl_seconds": 300,
      "max_results": 50,
      "auto_index": true
    }
  },
  "logging": {
    "level": "info",
    "include_timestamps": true,
    "log_file": ".logs/mcp.log"
  }
}
