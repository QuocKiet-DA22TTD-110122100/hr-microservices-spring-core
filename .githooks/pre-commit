#!/bin/sh
# Run repository secret scan before each commit.

if command -v pwsh >/dev/null 2>&1; then
  pwsh -NoProfile -ExecutionPolicy Bypass -File "scripts/scan-secrets.ps1"
  exit $?
fi

if command -v powershell >/dev/null 2>&1; then
  powershell -NoProfile -ExecutionPolicy Bypass -File "scripts/scan-secrets.ps1"
  exit $?
fi

echo "No PowerShell runtime found (pwsh/powershell). Cannot run secret scan." >&2
exit 1
