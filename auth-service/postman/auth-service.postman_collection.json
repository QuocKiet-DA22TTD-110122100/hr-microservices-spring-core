        {
          "name": "Internal Sign - Signed Headers",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var timestamp = Date.now().toString();",
                  "var payload = 'internal-test';",
                  "pm.collectionVariables.set('internalTimestamp', timestamp);",
                  "pm.sendRequest({",
                  "  url: pm.collectionVariables.get('baseUrl') + '/kms/sign',",
                  "  method: 'POST',",
                  "  header: { 'Content-Type': 'application/json' },",
                  "  body: { mode: 'raw', raw: JSON.stringify({ payload: payload + timestamp }) }",
                  "}, function (err, res) {",
                  "  if (err) { throw err; }",
                  "  var body = res.json();",
                  "  pm.collectionVariables.set('internalSignature', body.signature);",
                  "  pm.collectionVariables.set('internalKeyId', body.keyId);",
                  "});"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "var body = pm.response.json();",
                  "pm.expect(body.signature).to.be.a('string');",
                  "pm.expect(body.keyId).to.be.a('string');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Internal-Timestamp",
                "value": "{{internalTimestamp}}"
              },
              {
                "key": "X-Internal-Signature",
                "value": "{{internalSignature}}"
              },
              {
                "key": "X-Internal-Key-Id",
                "value": "{{internalKeyId}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"payload\": \"internal-test\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/kms/internal/sign",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "kms",
                "internal",
                "sign"
              ]
            },
            "description": "Positive test: internal endpoint with valid signature headers should return 200 when request originates from internal IP."
          }
