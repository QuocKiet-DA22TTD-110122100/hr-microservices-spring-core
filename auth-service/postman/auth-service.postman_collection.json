  "item": [
    {
      "name": "IAM",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var currentUsername = pm.collectionVariables.get('registeredUsername');",
                  "var currentPassword = pm.collectionVariables.get('registeredPassword');",
                  "if (!currentUsername) {",
                  "  pm.collectionVariables.set('registeredUsername', 'user_' + Date.now());",
                  "}",
                  "if (!currentPassword) {",
                  "  pm.collectionVariables.set('registeredPassword', 'Pass@12345');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "var body = pm.response.json();",
                  "pm.expect(body.userId).to.be.a('string');",
                  "pm.expect(body.username).to.eql(pm.collectionVariables.get('registeredUsername'));",
                  "pm.expect(body.role).to.eql('USER');",
                  "pm.collectionVariables.set('registeredUserId', body.userId);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{userToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{registeredUsername}}\",\n  \"password\": \"{{registeredPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/iam/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "iam",
                "register"
              ]
            },
            "description": "Register a new user with default role USER."
          }
        },
