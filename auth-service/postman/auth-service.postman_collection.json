        {
          "name": "Verify Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{token}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/iam/verify",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "iam",
                "verify"
              ]
            },
            "description": "Verify JWT signature and claims using public key from JWKS."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var body = pm.response.json();",
                  "pm.expect(body.valid).to.eql(true);",
                  "pm.expect(body.claims).to.be.an('object');",
                  "pm.expect(body.claims.username).to.be.a('string');"
                ]
              }
            }
          ]
        },
