						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"{{test_username}}_iam\",\n    \"password\": \"{{test_password}}\",\n    \"email\": \"{{test_email}}\"\n}"
						},
						"url": {
							"raw": "{{api_gateway_url}}/iam/user/register",
							"host": ["{{api_gateway_url}}"],
							"path": ["iam", "user", "register"]
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('IAM User registration successful', function () {",
									"    pm.response.to.have.status(200);",
									"    const responseJson = pm.response.json();",
									"    pm.expect(responseJson).to.have.property('accessToken');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					]
				}
			]
