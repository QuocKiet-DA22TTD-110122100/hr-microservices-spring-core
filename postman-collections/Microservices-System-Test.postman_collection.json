		{
			"name": "Authentication Endpoints",
			"description": "Test tất cả authentication endpoints",
			"item": [
				{
					"name": "Register via /api/v1/auth/register",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"{{test_username}}_v1\",\n    \"password\": \"{{test_password}}\",\n    \"email\": \"{{test_email}}\"\n}"
						},
						"url": {
							"raw": "{{api_gateway_url}}/api/v1/auth/register",
							"host": ["{{api_gateway_url}}"],
							"path": ["api", "v1", "auth", "register"]
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// FIX: Enhanced test để validate JWT token response",
									"pm.test('Registration successful - Status 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response contains required fields', function () {",
									"    const responseJson = pm.response.json();",
									"    pm.expect(responseJson).to.have.property('message');",
									"    pm.expect(responseJson).to.have.property('accessToken');",
									"    pm.expect(responseJson).to.have.property('tokenType');",
									"    pm.expect(responseJson).to.have.property('expiresIn');",
									"    pm.expect(responseJson).to.have.property('user');",
									"});",
									"",
									"pm.test('JWT token is valid format', function () {",
									"    const responseJson = pm.response.json();",
									"    const token = responseJson.accessToken;",
									"    pm.expect(token).to.be.a('string');",
									"    pm.expect(token.split('.')).to.have.lengthOf(3); // JWT has 3 parts",
									"    pm.environment.set('auth_token_v1', token);",
									"});",
									"",
									"pm.test('Response time under 2 seconds', function () {",
									"    pm.expect(pm.response.responseTime).to.be.below(2000);",
									"});",
									"",
									"console.log('✅ /api/v1/auth/register test passed - JWT token received');"
								],
								"type": "text/javascript"
							}
						}
					]
				},
				{
					"name": "Login via /api/v1/auth/login",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"{{test_username}}_v1\",\n    \"password\": \"{{test_password}}\"\n}"
						},
						"url": {
							"raw": "{{api_gateway_url}}/api/v1/auth/login",
							"host": ["{{api_gateway_url}}"],
							"path": ["api", "v1", "auth", "login"]
