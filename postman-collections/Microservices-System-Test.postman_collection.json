		{
			"name": "Error Handling Tests",
			"description": "Test error scenarios và edge cases",
			"item": [
				{
					"name": "Invalid Endpoint Test",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{api_gateway_url}}/invalid/endpoint",
							"host": ["{{api_gateway_url}}"],
							"path": ["invalid", "endpoint"]
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Invalid endpoint returns 404', function () {",
									"    pm.response.to.have.status(404);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					]
				},
				{
					"name": "Malformed JSON Test",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{ invalid json }"
						},
						"url": {
							"raw": "{{api_gateway_url}}/api/v1/auth/register",
							"host": ["{{api_gateway_url}}"],
							"path": ["api", "v1", "auth", "register"]
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Malformed JSON handled gracefully', function () {",
									"    pm.expect(pm.response.code).to.be.oneOf([400, 500]);",
									"    pm.expect(pm.response.code).to.not.equal(404);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					]
				},
				{
					"name": "FIX VERIFICATION: /api/v1/auth/register No Longer Returns 404",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"fix_test_user\",\n    \"password\": \"testpass123\",\n    \"email\": \"fixtest@example.com\"\n}"
						},
						"url": {
							"raw": "{{api_gateway_url}}/api/v1/auth/register",
							"host": ["{{api_gateway_url}}"],
							"path": ["api", "v1", "auth", "register"]
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// FIX VERIFICATION: This test proves the 404 bug is fixed",
									"pm.test('🔧 FIX VERIFIED: No longer returns 404 NOT_FOUND', function () {",
									"    pm.expect(pm.response.code).to.not.equal(404);",
									"    pm.expect(pm.response.text()).to.not.include('No static resource');",
									"});",
									"",
									"pm.test('🔧 FIX VERIFIED: Returns successful response', function () {",
									"    pm.expect(pm.response.code).to.equal(200);",
									"    const responseJson = pm.response.json();",
									"    pm.expect(responseJson).to.have.property('accessToken');",
									"});",
									"",
									"pm.test('🔧 FIX VERIFIED: Route mapping works correctly', function () {",
									"    // This proves /api/v1/auth/register -> /iam/auth/register mapping works",
									"    const responseJson = pm.response.json();",
									"    pm.expect(responseJson.message).to.include('Register success');",
									"});",
									"",
									"console.log('🎉 SUCCESS: /api/v1/auth/register fix is working!');"
								],
								"type": "text/javascript"
							}
						}
					]
				}
			]
		}
