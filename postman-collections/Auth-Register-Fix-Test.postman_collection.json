{
	"info": {
		"_postman_id": "auth-register-fix-test",
		"name": "Auth Register Fix Test Collection",
		"description": "Test collection để verify fix cho lỗi 404 NOT_FOUND của endpoint /api/v1/auth/register",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Bug Condition Tests",
			"description": "Tests để verify bug condition và expected behavior",
			"item": [
				{
					"name": "1. Test /api/v1/auth/register (NEW ENDPOINT)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// FIX: Property test cho bug condition - API V1 Auth Register Route",
									"// Tag: Feature: auth-register-endpoint-404-fix, Property 1: Bug condition validation",
									"",
									"pm.test('Status code should be 200 (not 404)', function () {",
									"    pm.response.to.have.status(200);",
									"    // Nếu vẫn 404, bug chưa được fix",
									"});",
									"",
									"pm.test('Response should be JSON (not static resource error)', function () {",
									"    pm.response.to.be.json;",
									"    // Nếu trả về text 'No static resource', bug chưa được fix",
									"});",
									"",
									"pm.test('Response should contain authentication data', function () {",
									"    const responseJson = pm.response.json();",
									"    pm.expect(responseJson).to.have.property('message');",
									"    pm.expect(responseJson).to.have.property('accessToken');",
									"    pm.expect(responseJson).to.have.property('user');",
									"});",
									"",
									"pm.test('JWT token should be generated', function () {",
									"    const responseJson = pm.response.json();",
									"    pm.expect(responseJson.accessToken).to.be.a('string');",
									"    pm.expect(responseJson.accessToken.length).to.be.greaterThan(10);",
									"});",
									"",
									"pm.test('Response time should be under 500ms', function () {",
									"    pm.expect(pm.response.responseTime).to.be.below(500);",
									"});",
									"",
									"// Store token for subsequent tests",
									"if (pm.response.code === 200) {",
									"    const responseJson = pm.response.json();",
									"    pm.environment.set('auth_token', responseJson.accessToken);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"testuser_api_v1\",\n    \"password\": \"password123\",\n    \"email\": \"testuser@example.com\",\n    \"fullName\": \"Test User API V1\"\n}"
						},
						"url": {
							"raw": "{{api_gateway_url}}/api/v1/auth/register",
							"host": [
								"{{api_gateway_url}}"
							],
							"path": [
								"api",
								"v1",
								"auth",
								"register"
							]
						},
						"description": "Test endpoint /api/v1/auth/register - should route to /iam/auth/register on mock-service"
					}
				},
