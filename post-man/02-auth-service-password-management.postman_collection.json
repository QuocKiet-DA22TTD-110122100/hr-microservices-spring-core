{
  "info": {
    "name": "Auth Service - Password Management",
    "description": "Test password change, password policy validation, and password history",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "auth_base_url",
      "value": "http://localhost:8086",
      "type": "string"
    },
    {
      "key": "test_username",
      "value": "pwdtest_{{$randomInt}}",
      "type": "string"
    },
    {
      "key": "old_password",
      "value": "OldPass@123",
      "type": "string"
    },
    {
      "key": "new_password",
      "value": "NewPass@456",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Register User for Password Test",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Registration successful', function () {",
              "    pm.response.to.have.status(200);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{test_username}}\",\n  \"password\": \"{{old_password}}\",\n  \"role\": \"USER\"\n}"
        },
        "url": {
          "raw": "{{auth_base_url}}/iam/register",
          "host": ["{{auth_base_url}}"],
          "path": ["iam", "register"]
        }
      },
      "response": []
    },
    {
      "name": "2. Change Password - Success",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Password changed successfully', function () {",
              "    pm.response.to.have.status(200);",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('message');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{test_username}}\",\n  \"oldPassword\": \"{{old_password}}\",\n  \"newPassword\": \"{{new_password}}\"\n}"
        },
        "url": {
          "raw": "{{auth_base_url}}/iam/change-password",
          "host": ["{{auth_base_url}}"],
          "path": ["iam", "change-password"]
        },
        "description": "Change password with valid old password"
      },
      "response": []
    },
    {
      "name": "3. Login with New Password",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Login with new password successful', function () {",
              "    pm.response.to.have.status(200);",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('token');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{test_username}}\",\n  \"password\": \"{{new_password}}\"\n}"
        },
        "url": {
          "raw": "{{auth_base_url}}/iam/login",
          "host": ["{{auth_base_url}}"],
          "path": ["iam", "login"]
        }
      },
      "response": []
    },
    {
      "name": "4. Change Password - Reuse Old Password (Should Fail)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Should reject reused password', function () {",
              "    pm.response.to.have.status(400);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{test_username}}\",\n  \"oldPassword\": \"{{new_password}}\",\n  \"newPassword\": \"{{old_password}}\"\n}"
        },
        "url": {
          "raw": "{{auth_base_url}}/iam/change-password",
          "host": ["{{auth_base_url}}"],
          "path": ["iam", "change-password"]
        },
        "description": "Try to reuse a password from history (should fail)"
      },
      "response": []
    },
    {
      "name": "5. Change Password - Weak Password (Should Fail)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Should reject weak password', function () {",
              "    pm.response.to.have.status(400);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{test_username}}\",\n  \"oldPassword\": \"{{new_password}}\",\n  \"newPassword\": \"weak\"\n}"
        },
        "url": {
          "raw": "{{auth_base_url}}/iam/change-password",
          "host": ["{{auth_base_url}}"],
          "path": ["iam", "change-password"]
        },
        "description": "Try to set a weak password (should fail validation)"
      },
      "response": []
    }
  ]
}
