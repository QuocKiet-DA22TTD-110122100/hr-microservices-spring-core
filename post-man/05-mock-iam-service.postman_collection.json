{
  "info": {
    "name": "05 - Mock IAM Service Tests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "IAM Auth Register",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-Internal-Secret", "value": "{{internal_secret}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{test_username}}\",\n  \"password\": \"{{test_password}}\"\n}"
        },
        "url": "{{mock_service_url}}/iam/auth/register"
      }
    },
    {
      "name": "IAM Auth Login",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-Internal-Secret", "value": "{{internal_secret}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{test_username}}\",\n  \"password\": \"{{test_password}}\"\n}"
        },
        "url": "{{mock_service_url}}/iam/auth/login"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "if (json && json.accessToken) {",
              "    pm.environment.set('auth_token', json.accessToken);",
              "}",
              "pm.test('Login status is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "IAM User Profile",
      "request": {
        "method": "GET",
        "header": [
          { "key": "X-Auth-User", "value": "{{test_username}}" },
          { "key": "X-Internal-Secret", "value": "{{internal_secret}}" }
        ],
        "url": "{{mock_service_url}}/iam/user/profile"
      }
    },
    {
      "name": "API v1 Auth Login",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-Internal-Secret", "value": "{{internal_secret}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{test_username}}\",\n  \"password\": \"{{test_password}}\"\n}"
        },
        "url": "{{mock_service_url}}/api/v1/auth/login"
      }
    }
  ]
}