{
  "info": {
    "name": "03 - KMS Service Tests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health (/kms/health)",
      "request": {
        "method": "GET",
        "url": "{{kms_service_url}}/kms/health"
      }
    },
    {
      "name": "Info (/kms/info)",
      "request": {
        "method": "GET",
        "url": "{{kms_service_url}}/kms/info"
      }
    },
    {
      "name": "Sign (/kms/sign)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"payload\": \"postman-smoke-payload\"\n}"
        },
        "url": "{{kms_service_url}}/kms/sign"
      }
    },
    {
      "name": "Internal Sign (/kms/internal/sign)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"payload\": \"postman-internal-sign\"\n}"
        },
        "url": "{{kms_service_url}}/kms/internal/sign"
      }
    },
    {
      "name": "JWKS (/kms/internal/.well-known/jwks.json)",
      "request": {
        "method": "GET",
        "url": "{{kms_service_url}}/kms/internal/.well-known/jwks.json"
      }
    }
  ]
}