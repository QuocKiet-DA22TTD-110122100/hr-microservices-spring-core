{
  "info": {
    "name": "06 - User Journey Via API Gateway",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Run this after service-level collections (01-05)."
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const method = pm.request.method;",
          "const resolvedRawUrl = pm.variables.replaceIn(pm.request.url.toString());",
          "if (/\\s/.test(resolvedRawUrl)) {",
          "    throw new Error('Request URL contains whitespace. Remove spaces in URL, especially between {{gateway_url}} and /api/...');",
          "}",
          "const pathParts = (pm.request.url && pm.request.url.path) ? pm.request.url.path : [];",
          "const path = '/' + pathParts.join('/');",
          "const timestamp = Math.floor(Date.now() / 1000).toString();",
          "const nonce = 'nonce-' + Date.now();",
          "",
          "let bodyRaw = '';",
          "if (pm.request.body && pm.request.body.mode === 'raw') {",
          "    bodyRaw = pm.variables.replaceIn(pm.request.body.raw || '');",
          "}",
          "const bodyHash = bodyRaw ? CryptoJS.SHA256(bodyRaw).toString(CryptoJS.enc.Hex) : '';",
          "const canonical = [method, path, timestamp, nonce, bodyHash].join('\\n');",
          "",
          "const accessKeyId = pm.environment.get('access_key_id') || pm.environment.get('ACCESS_KEY_ID');",
          "const secret = pm.environment.get('access_key_secret') || pm.environment.get('SECRET_KEY');",
          "if (!accessKeyId || !secret) {",
          "    throw new Error('Missing access key variables. Set access_key_id/access_key_secret (or ACCESS_KEY_ID/SECRET_KEY).');",
          "}",
          "const signature = CryptoJS.HmacSHA256(canonical, secret).toString(CryptoJS.enc.Base64);",
          "",
          "pm.request.headers.upsert({ key: 'X-Access-Key-Id', value: accessKeyId });",
          "pm.request.headers.upsert({ key: 'X-Timestamp', value: timestamp });",
          "pm.request.headers.upsert({ key: 'X-Nonce', value: nonce });",
          "pm.request.headers.upsert({ key: 'X-Signature', value: signature });",
          "",
          "const token = pm.environment.get('auth_token');",
          "if (path === '/iam/user/register' || path === '/iam/user/login') {",
          "    pm.request.headers.remove('Authorization');",
          "} else {",
          "    if (!token) {",
          "        throw new Error('Missing auth_token. Run Step 2 - Login User first.');",
          "    }",
          "    pm.request.headers.upsert({ key: 'Authorization', value: 'Bearer ' + token });",
          "}",
          "",
          "pm.environment.set('last_canonical', canonical);"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Step 1 - Register User (/iam/user/register)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{test_username}}\",\n  \"password\": \"{{test_password}}\"\n}"
        },
        "url": "{{gateway_url}}/iam/user/register"
      }
    },
    {
      "name": "Step 2 - Login User (/iam/user/login)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{test_username}}\",\n  \"password\": \"{{test_password}}\"\n}"
        },
        "url": "{{gateway_url}}/iam/user/login"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Login through gateway success', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "const token = (json && (json.accessToken || json.token)) ? (json.accessToken || json.token) : '';",
              "pm.environment.set('auth_token', token);",
              "pm.test('Token is captured from login response', function () {",
              "    pm.expect(token).to.be.a('string').and.not.empty;",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Step 3 - Get User Profile (/iam/user/profile)",
      "request": {
        "method": "GET",
        "url": "{{gateway_url}}/iam/user/profile"
      }
    },
    {
      "name": "Step 4 - HR Get Employees (/api/hr/employees)",
      "request": {
        "method": "GET",
        "url": "{{gateway_url}}/api/hr/employees"
      }
    },
    {
      "name": "Step 5 - HR Create Employee (/api/hr/employees)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Journey Employee\",\n  \"position\": \"Engineer\"\n}"
        },
        "url": "{{gateway_url}}/api/hr/employees"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "if (json && json.id) {",
              "    pm.environment.set('employee_id', json.id);",
              "}",
              "pm.test('HR create employee success', function () {",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Step 6 - HR Delete Employee (/api/hr/employees/{id})",
      "request": {
        "method": "DELETE",
        "url": "{{gateway_url}}/api/hr/employees/{{employee_id}}"
      }
    }
  ]
}