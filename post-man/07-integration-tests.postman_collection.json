{
  "info": {
    "name": "07 - Integration Tests",
    "description": "End-to-end integration tests for the entire microservices system",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Checks",
      "item": [
        {
          "name": "Check All Services Health",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('All services are healthy', function() {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{gateway_url}}/actuator/health",
              "host": ["{{gateway_url}}"],
              "path": ["actuator", "health"]
            }
          }
        },
        {
          "name": "Check Eureka Cluster",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Eureka is accessible', function() {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{eureka_peer1_url}}/actuator/health",
              "host": ["{{eureka_peer1_url}}"],
              "path": ["actuator", "health"]
            },
            "auth": {
              "type": "basic",
              "basic": [
                {"key": "username", "value": "{{eureka_username}}"},
                {"key": "password", "value": "{{eureka_password}}"}
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Complete User Journey",
      "item": [
        {
          "name": "1. Register New User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('User registered successfully', function() {",
                  "    pm.response.to.have.status(200);",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.success).to.be.true;",
                  "    pm.environment.set('test_user_id', response.data.userId);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser_{{$timestamp}}\",\n  \"password\": \"Test@123456\",\n  \"email\": \"test{{$timestamp}}@example.com\",\n  \"fullName\": \"Test User\"\n}"
            },
            "url": {
              "raw": "{{gateway_url}}/api/iam/register",
              "host": ["{{gateway_url}}"],
              "path": ["api", "iam", "register"]
            }
          }
        },
        {
          "name": "2. Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Login successful', function() {",
                  "    pm.response.to.have.status(200);",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.success).to.be.true;",
                  "    pm.expect(response.data.token).to.exist;",
                  "    pm.environment.set('auth_token', response.data.token);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{test_username}}\",\n  \"password\": \"{{test_password}}\"\n}"
            },
            "url": {
              "raw": "{{gateway_url}}/api/iam/login",
              "host": ["{{gateway_url}}"],
              "path": ["api", "iam", "login"]
            }
          }
        },
        {
          "name": "3. Verify Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Token is valid', function() {",
                  "    pm.response.to.have.status(200);",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.success).to.be.true;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {"key": "Authorization", "value": "Bearer {{auth_token}}"}
            ],
            "url": {
              "raw": "{{gateway_url}}/api/iam/verify",
              "host": ["{{gateway_url}}"],
              "path": ["api", "iam", "verify"]
            }
          }
        },
        {
          "name": "4. Access HR Service",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('HR service accessible', function() {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {"key": "Authorization", "value": "Bearer {{auth_token}}"}
            ],
            "url": {
              "raw": "{{gateway_url}}/api/hr/employees",
              "host": ["{{gateway_url}}"],
              "path": ["api", "hr", "employees"]
            }
          }
        },
        {
          "name": "5. Logout",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Logout successful', function() {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{auth_token}}"}
            ],
            "url": {
              "raw": "{{gateway_url}}/api/iam/logout",
              "host": ["{{gateway_url}}"],
              "path": ["api", "iam", "logout"]
            }
          }
        }
      ]
    },
    {
      "name": "Security Tests",
      "item": [
        {
          "name": "Test Invalid Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Invalid token rejected', function() {",
                  "    pm.response.to.have.status(401);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {"key": "Authorization", "value": "Bearer invalid_token_12345"}
            ],
            "url": {
              "raw": "{{gateway_url}}/api/iam/verify",
              "host": ["{{gateway_url}}"],
              "path": ["api", "iam", "verify"]
            }
          }
        },
        {
          "name": "Test Missing Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Missing token rejected', function() {",
                  "    pm.response.to.have.status(401);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{gateway_url}}/api/iam/verify",
              "host": ["{{gateway_url}}"],
              "path": ["api", "iam", "verify"]
            }
          }
        }
      ]
    }
  ]
}
