{
  "info": {
    "name": "HR Microservices - PASS Once Demo",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Lightweight one-click demo collection: health, login, verify, read-only APIs, and monitoring checks."
  },
  "item": [
    {
      "name": "01 - Health Checks",
      "item": [
        {
          "name": "Gateway Health",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": "{{gateway_url}}/actuator/health"
          }
        },
        {
          "name": "Auth Service Health",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": "{{auth_service_url}}/actuator/health"
          }
        },
        {
          "name": "HR Service Health (Direct)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "X-Internal-Secret", "value": "{{internal_secret}}" }
            ],
            "url": "{{hr_service_url}}/actuator/health"
          }
        },
        {
          "name": "KMS Health",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": "{{kms_service_url}}/kms/health"
          }
        },
        {
          "name": "Prometheus Healthy",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": "{{prometheus_url}}/-/healthy"
          }
        },
        {
          "name": "Grafana Health",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": "{{grafana_url}}/api/health"
          }
        }
      ]
    },
    {
      "name": "02 - Auth via Gateway (Read-Safe)",
      "item": [
        {
          "name": "Login (Existing User)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Internal-Secret", "value": "{{internal_secret}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{demo_username}}\",\n  \"password\": \"{{demo_password}}\"\n}"
            },
            "url": "{{gateway_url}}/api/iam/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "const token = json.token || (json.data && (json.data.token || json.data.accessToken));",
                  "if (token) pm.environment.set('demo_token', token);",
                  "pm.test('token captured', function () {",
                  "  pm.expect(pm.environment.get('demo_token')).to.be.a('string').and.not.empty;",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Verify Token",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{demo_token}}" },
              { "key": "X-Internal-Secret", "value": "{{internal_secret}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{demo_token}}\"\n}"
            },
            "url": "{{gateway_url}}/api/iam/verify"
          }
        }
      ]
    },
    {
      "name": "03 - HR Read APIs via Gateway",
      "item": [
        {
          "name": "Get Organization Units",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{demo_token}}" }
            ],
            "url": "{{gateway_url}}/api/hr/organization-units"
          }
        },
        {
          "name": "Get Organization Tree",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{demo_token}}" }
            ],
            "url": "{{gateway_url}}/api/hr/organization-units/tree"
          }
        },
        {
          "name": "Get Departments",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{demo_token}}" }
            ],
            "url": "{{gateway_url}}/api/hr/departments"
          }
        },
        {
          "name": "Get Employees",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{demo_token}}" }
            ],
            "url": "{{gateway_url}}/api/hr/employees"
          }
        }
      ]
    },
    {
      "name": "04 - KMS Read APIs (Direct)",
      "item": [
        {
          "name": "KMS Home",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": "{{kms_service_url}}/kms/"
          }
        },
        {
          "name": "KMS Info",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": "{{kms_service_url}}/kms/info"
          }
        },
        {
          "name": "KMS Keys",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": "{{kms_service_url}}/kms/keys"
          }
        },
        {
          "name": "KMS JWKS",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": "{{kms_service_url}}/kms/internal/.well-known/jwks.json"
          }
        }
      ]
    },
    {
      "name": "05 - Monitoring Snapshot",
      "item": [
        {
          "name": "Prom Query - Services Up",
          "request": {
            "method": "GET",
            "url": "{{prometheus_url}}/api/v1/query?query=sum(up{job=~\"api-gateway|auth-service|hr-service|kms-service\"})"
          }
        },
        {
          "name": "Prom Query - Gateway Request Rate",
          "request": {
            "method": "GET",
            "url": "{{prometheus_url}}/api/v1/query?query=sum(rate(http_server_requests_seconds_count{job=\"api-gateway\"}[5m]))"
          }
        },
        {
          "name": "Prom Query - Gateway 429 Rate",
          "request": {
            "method": "GET",
            "url": "{{prometheus_url}}/api/v1/query?query=sum(rate(http_server_requests_seconds_count{job=\"api-gateway\",status=\"429\"}[5m]))"
          }
        }
      ]
    }
  ]
}
