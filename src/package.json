{
  "name": "hr-microservices-integration",
  "version": "1.0.0",
  "description": "HR Microservices with ECC + CodeGraph integration",
  "private": true,
  "scripts": {
    "ecc:install": "npm install -g ecc-universal",
    "ecc:setup": "node scripts/ecc-setup.js",
    "codegraph:install": "npm install -g @colbymchenry/codegraph",
    "codegraph:init": "node scripts/codegraph-init.js",
    "codegraph:sync": "codegraph sync",
    "integration:setup": "npm run ecc:install && npm run codegraph:install && npm run ecc:setup && npm run codegraph:init",
    "integration:verify": "node scripts/verify-integration.js",
    "lint": "eslint . --max-warnings 0",
    "test": "jest"
  },
  "keywords": [
    "ecc",
    "codegraph",
    "mcp",
    "agents",
    "hr-microservices"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "eslint": "^9.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "autoskills": "^0.3.6"
  }
}
