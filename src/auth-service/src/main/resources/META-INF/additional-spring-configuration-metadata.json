{
  "groups": [
    {
      "name": "auth",
      "type": "java.lang.Object",
      "description": "Authentication service custom configuration."
    },
    {
      "name": "app",
      "type": "java.lang.Object",
      "description": "Application custom configuration root."
    },
    {
      "name": "sync",
      "type": "java.lang.Object",
      "description": "Synchronization-related custom configuration root."
    }
  ],
  "properties": [
    {
      "name": "auth.login-attempt.max-failures",
      "type": "java.lang.Integer",
      "description": "Maximum failed login attempts before lockout."
    },
    {
      "name": "auth.login-attempt.lock-minutes",
      "type": "java.lang.Integer",
      "description": "Account lock duration in minutes."
    },
    {
      "name": "auth.password-policy.expiry-days",
      "type": "java.lang.Integer",
      "description": "Password expiry in days."
    },
    {
      "name": "app.security.2fa.issuer",
      "type": "java.lang.String",
      "description": "TOTP issuer label."
    },
    {
      "name": "app.security.2fa.time-step-seconds",
      "type": "java.lang.Long",
      "description": "TOTP time-step in seconds."
    },
    {
      "name": "app.security.2fa.digits",
      "type": "java.lang.Integer",
      "description": "Number of TOTP digits."
    },
    {
      "name": "app.security.2fa.window",
      "type": "java.lang.Integer",
      "description": "Accepted TOTP verification window."
    },
    {
      "name": "sync.hr.enabled",
      "type": "java.lang.Boolean",
      "description": "Enable background user sync to HR service."
    },
    {
      "name": "sync.hr.base-url",
      "type": "java.lang.String",
      "description": "Base URL for HR sync endpoint."
    },
    {
      "name": "sync.hr.internal-secret",
      "type": "java.lang.String",
      "description": "Internal secret used for sync calls."
    },
    {
      "name": "sync.hr.fixed-delay-ms",
      "type": "java.lang.Long",
      "description": "Scheduler fixed delay in milliseconds."
    },
    {
      "name": "sync.hr.batch-size",
      "type": "java.lang.Integer",
      "description": "Maximum records per sync batch."
    },
    {
      "name": "sync.hr.max-retries",
      "type": "java.lang.Integer",
      "description": "Maximum sync retries."
    },
    {
      "name": "sync.hr.retry-base-delay-seconds",
      "type": "java.lang.Integer",
      "description": "Base retry delay in seconds for sync backoff."
    }
  ]
}
