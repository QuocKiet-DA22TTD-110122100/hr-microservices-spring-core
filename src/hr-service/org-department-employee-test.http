### HR Domain quick test (OrganizationUnit + Department + Employee)
### Required headers must match gateway/internal policy in hr-service

@baseUrl = http://localhost:8082
@internalSecret = change_me
@adminRole = ADMIN

### 1) Create root organization unit
POST {{baseUrl}}/organization-units
X-Internal-Secret: {{internalSecret}}
X-Auth-Role: {{adminRole}}
Content-Type: application/json

{
  "name": "Tap doan ABC",
  "code": "CORP-001",
  "level": "CORPORATION"
}

### 2) Create member company under parent id=1 (adjust parentId as needed)
POST {{baseUrl}}/organization-units
X-Internal-Secret: {{internalSecret}}
X-Auth-Role: {{adminRole}}
Content-Type: application/json

{
  "name": "Cong ty thanh vien SG",
  "code": "CT-SG-001",
  "level": "MEMBER_COMPANY",
  "parentId": 1
}

### 3) Get organization tree
GET {{baseUrl}}/organization-units/tree
X-Internal-Secret: {{internalSecret}}

### 4) Create department under organization unit id=2
POST {{baseUrl}}/departments
X-Internal-Secret: {{internalSecret}}
X-Auth-Role: {{adminRole}}
Content-Type: application/json

{
  "name": "Phong Ky Thuat",
  "code": "IT-001",
  "organizationUnitId": 2
}

### 5) Get departments by organizationUnitId
GET {{baseUrl}}/departments?organizationUnitId=2
X-Internal-Secret: {{internalSecret}}

### 6) Create employee with departmentId=1
POST {{baseUrl}}/employees
X-Internal-Secret: {{internalSecret}}
X-Auth-Role: {{adminRole}}
Content-Type: application/json

{
  "name": "Nguyen Van A",
  "position": "Developer",
  "departmentId": 1
}

### 7) List employees
GET {{baseUrl}}/employees
X-Internal-Secret: {{internalSecret}}

### 8) List employees by departmentId
GET {{baseUrl}}/employees?departmentId=1
X-Internal-Secret: {{internalSecret}}

### 9) Update employee id=1
PUT {{baseUrl}}/employees/1
X-Internal-Secret: {{internalSecret}}
X-Auth-Role: {{adminRole}}
Content-Type: application/json

{
  "name": "Nguyen Van A Updated",
  "position": "Senior Developer",
  "departmentId": 1
}
