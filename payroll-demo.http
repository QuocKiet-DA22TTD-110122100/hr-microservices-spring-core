@gateway = http://localhost:8080
@username = admin
@password = Admin@123
@employeeId = 6
@yearMonth = 2026-06
@payrollId = 3

### 1. Login demo user
# @name login
POST {{gateway}}/api/xac-thuc/dang-nhap
Content-Type: application/json

{
  "username": "{{username}}",
  "password": "{{password}}"
}

### 2. Validate token
POST {{gateway}}/api/xac-thuc/kiem-tra
Content-Type: application/json
Authorization: Bearer {{login.response.body.token}}

{
  "token": "{{login.response.body.token}}"
}

### 3. List employees
GET {{gateway}}/api/hr/employees
Authorization: Bearer {{login.response.body.token}}

### 4. Create payroll run
POST {{gateway}}/api/payroll/runs
Content-Type: application/json
Authorization: Bearer {{login.response.body.token}}

{
  "yearMonth": "{{yearMonth}}",
  "requestedBy": "{{username}}",
  "source": "http-demo"
}

### 5. Calculate payroll for employee
GET {{gateway}}/api/payroll/{{employeeId}}/calculate?yearMonth={{yearMonth}}
Authorization: Bearer {{login.response.body.token}}

### 6. Get current payroll
GET {{gateway}}/api/payroll/{{employeeId}}/current
Authorization: Bearer {{login.response.body.token}}

### 7. Approve payroll
PUT {{gateway}}/api/chi-tra/{{payrollId}}/phe-duyet
Authorization: Bearer {{login.response.body.token}}

### 8. Reject payroll to DRAFT
PUT {{gateway}}/api/chi-tra/{{payrollId}}/tu-choi
Content-Type: application/json
Authorization: Bearer {{login.response.body.token}}

{
  "reason": "Can kiem tra lai du lieu khau tru"
}

### 9. Process approved payroll
PUT {{gateway}}/api/chi-tra/{{payrollId}}/xu-ly
Authorization: Bearer {{login.response.body.token}}

### 10. Payroll history
GET {{gateway}}/api/payroll/{{employeeId}}/history
Authorization: Bearer {{login.response.body.token}}
