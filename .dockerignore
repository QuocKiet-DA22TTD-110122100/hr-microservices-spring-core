# .dockerignore - Exclude files from Docker build context
# This reduces build context size and speeds up builds

# VCS
.git
.gitignore
.github

# IDE
.vscode
.idea
*.iml
*.swp
*.swo

# Build artifacts
target/
build/
dist/
*.class
*.jar
*.war
*.ear

# Dependencies
node_modules/
npm-debug.log*
# Keep .mvn/ - needed for Maven builds!
# .mvn/wrapper/maven-wrapper.jar
# .mvn/wrapper/maven-wrapper.properties

# OS
.DS_Store
Thumbs.db
*.log

# Documentation (optional - remove if needed)
*.md
docs/

# Test files (optional - uncomment if needed)
# src/test/
# *Test.java
# *IT.java

# Environment files
.env
.env.local
.env.*.local

# Temporary files
*.tmp
*.temp
~*

# Docker
Dockerfile*
docker-compose*.yml
.docker/

# Misc
.qodo/
certs/
logs/
phase3-validation.log
